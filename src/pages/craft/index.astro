---
import Aside from '@/components/AsideNavigation.astro'
import CraftCard from '@/components/CraftCard.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllCrafts } from '@/lib/data-utils'

const entries = await getAllCrafts()
---

<Layout class="relative max-w-7xl px-0 pt-16">
  <PageHead slot="head" title="Craft" description="Web animations & experiments" />
  <main
    class="relative grid grid-cols-1 gap-4 md:grid-cols-4 md:gap-8 lg:grid-cols-[1fr_35rem_1fr] items-start"
  >
    <Aside />
    <div class="space-y-12">
      <div class="flex flex-col">
        <h1 class="text-lg">Craft</h1>
        <p class="text-md text-muted-foreground">Web animations & experiments</p>
      </div>
      {
        entries.length > 0 ? (
          <section class="flex flex-col gap-y-4">
            <ul class="flex flex-col gap-y-4">
              {entries.map((entry) => (
                <li>
                  <CraftCard entry={entry} />
                </li>
              ))}
            </ul>
          </section>
        ) : (
          <p class="text-muted-foreground text-sm">No craft entries yet.</p>
        )
      }
    </div>
  </main>
</Layout>
