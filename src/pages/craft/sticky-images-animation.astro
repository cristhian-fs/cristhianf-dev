---
import CraftLayout from '@/layouts/craft-layout.astro'
---

<CraftLayout craftId="sticky-images-animation">
  <section>
    <div class="cover"></div>
    <div class="animation-container">
      <div class="project">
        <div class="project_cover">
          <img
            src="https://images.unsplash.com/photo-1483921020237-2ff51e8e4b22?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt=""
          />
        </div>
        <div class="project_content">
          <div class="sticky">
            <div class="info">
              <p>Switzerland</p>
              <h2>Lauterbrunnen</h2>
            </div>
            <div class="thumb">
              <img
                src="https://images.unsplash.com/photo-1483921020237-2ff51e8e4b22?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                alt=""
              />
            </div>
          </div>
        </div>
      </div>
      <div class="project">
        <div class="project_cover">
          <img
            src="https://images.unsplash.com/photo-1730724742886-b0e36d1eb067?q=80&w=1932&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt=""
          />
        </div>
        <div class="project_content">
          <div class="sticky">
            <div class="info">
              <p>Namibia</p>
              <h2>Sossusvlei</h2>
            </div>
            <div class="thumb">
              <img
                src="https://images.unsplash.com/photo-1730724742886-b0e36d1eb067?q=80&w=1932&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                alt=""
              />
            </div>
          </div>
        </div>
      </div>
      <div class="project">
        <div class="project_cover">
          <img
            src="https://images.unsplash.com/photo-1532601224476-15c79f2f7a51?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt=""
          />
        </div>
        <div class="project_content">
          <div class="sticky">
            <div class="info">
              <p>Montenegro</p>
              <h2>Niksic</h2>
            </div>
            <div class="thumb">
              <img
                src="https://images.unsplash.com/photo-1532601224476-15c79f2f7a51?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                alt=""
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section-content">
    <div class="content container">
      <div class="content-wrapper">
        <h1>Lorem ipsum dolor sit amet</h1>
        <p>
          Adis congue nisl tincidunt purus est. Viverra nisl condimentum
          vestibulum porta per. Sapien tempus aenean vestibulum tristique
          volutpat malesuada netus ad facilisi. Volutpat condimentum erat
          viverra proin nunc mauris non platea dignissim. Mi dignissim phasellus
          quisque id metus sollicitudin. Diam donec a convallis suscipit
          finibus. Ante mollis sed semper convallis hendrerit mauris? Cubilia
          per class viverra aptent senectus diam curae.
        </p>
      </div>
      <div class="image-wrapper">
        <img
          src="https://images.unsplash.com/photo-1483921020237-2ff51e8e4b22?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
          alt=""
        />
      </div>
    </div>
  </section>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap');

    html.lenis,
    html.lenis body {
      height: auto;
    }

    .lenis.lenis-smooth {
      scroll-behavior: auto !important;
    }

    .lenis.lenis-smooth [data-lenis-prevent] {
      overscroll-behavior: contain;
    }

    .lenis.lenis-stopped {
      overflow: clip;
    }

    .lenis.lenis-smooth iframe {
      pointer-events: none;
    }

    section {
      font-family: 'Inter';
      font-size: 1.125rem;
      line-height: 1.75rem;
    }

    .project {
      position: relative;
      height: 80vh;
    }

    .content {
      display: flex;
      flex-direction: column;
      align-items: start;
      justify-content: start;
      gap: 2rem;
      margin: 0 auto;
      width: 100%;
      max-width: 1280px;
      padding: 4rem 1rem;
      min-height: 90vh;
    }

    .image-wrapper {
      min-height: 30vw;
      max-height: 100%;
      overflow: hidden;
      flex-shrink: 0;
      max-width: 100%;
      & img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
    }

    .content-wrapper {
      & h1 {
        font-size: 2.25rem; /* 36px */
        line-height: 2.5rem; /* 40px */
        letter-spacing: -0.05rem;
        font-weight: 600;
      }
      & p {
        font-size: 1rem;
        line-height: 1.5rem;
        margin-top: 1rem;
      }
    }

    @media (min-width: 601px) {
      .content {
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 4rem;
        max-width: 1280px;
        padding: 8rem 2rem;
      }

      .image-wrapper {
        max-width: 50%;
      }

      .content-wrapper {
        & h1 {
          font-size: 3rem; /* 48px */
          line-height: 1;
          letter-spacing: -0.05rem;
          font-weight: 600;
        }
        & p {
          font-size: 1.125rem; /* 18px */
          line-height: 1.75rem; /* 28px */
          margin-top: 1rem;
        }
      }
    }

    .project_cover {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      max-width: 100%;
      overflow: hidden;
      & img {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
      }

      &::before {
        content: '';
        background: linear-gradient(
          1turn,
          rgba(0, 0, 0, 0.4) 25%,
          rgba(0, 0, 0, 0.1) 65%
        );
        z-index: 1;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
      }
    }

    .thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    .info {
      color: hsl(0 0 100);
      & p {
        font-size: 1rem;
        font-weight: 400;
        line-height: 1.5;
      }

      & h2 {
        font-size: 4rem;
        font-weight: 500;
        letter-spacing: -0.25rem;
        line-height: 4.5rem;
      }
    }

    .sticky {
      align-items: start;
      justify-content: start;
      gap: 2rem;
      display: flex;
      flex-direction: column;
      height: 80vh;
      width: 100%;
      max-width: 1280px;
      padding-left: 1rem;
      padding-right: 1rem;
      padding-top: 4rem;
      padding-bottom: 4rem;
      position: relative;
      z-index: 2;
    }

    @media (min-width: 601px) {
      .project {
        height: 100vh;
        padding: 0;
        contain: paint;
      }

      .project .project_content {
        /* 3 times the screen size because it comes 100vh from the top and needs to be sticky more 100vh to bottom */
        height: 300vh;
        margin-top: -100vh;
        left: 0;
        right: 0;
        display: flex;
        z-index: 2;
      }

      .project:first-child .project_content {
        height: 200vh;
        top: 0;
        margin-top: 0;
      }
      .project:last-child .project_content {
        height: 200vh;
      }

      .sticky {
        align-items: center;
        justify-content: space-between;
        display: flex;
        flex-direction: row;
        height: 100vh;
        position: sticky;
        top: 0;
        margin: 0 auto;
        width: 100%;
        left: 0;
        max-width: 1280px;
        padding-left: 2rem;
        padding-right: 2rem;
      }

      .thumb {
        height: 30vw;
        width: 29vw;
        overflow: hidden;
      }
    }

    section {
      position: relative;
      background-color: var(--color-background);
      & .cover {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        pointer-events: none;
        background: rgb(0, 0, 0);
        z-index: 50;
        opacity: 0;
      }
    }

    section {
      position: relative;
      background-color: var(--color-background);
    }
  </style>
</CraftLayout>

<script>
  import gsap from 'gsap'
  import ScrollTrigger from 'gsap/ScrollTrigger'
  import Lenis from 'lenis'

  gsap.registerPlugin(ScrollTrigger)

  function setup() {
    // css variable
    document.documentElement.style.setProperty(
      '--vh',
      `${window.innerHeight * 0.01}px`,
    )

    // gsap registering
    gsap.registerPlugin(ScrollTrigger)

    //lenis

    const lenis = new Lenis()

    lenis.on('scroll', ScrollTrigger.update)

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000)
    })

    gsap.ticker.lagSmoothing(0)

    // selecting DOM elements

    const projects = document.querySelectorAll('.project')

    projects.forEach((project) => {
      const projectCover = project.querySelector('.project_cover')

      gsap.to(projectCover, {
        y: '20%',
        scrollTrigger: {
          trigger: project,
          start: 'top 0%',
          end: 'bottom 0%',
          scrub: true,
        },
      })
    })

    const sections = document.querySelectorAll('section')

    sections.forEach((section, index) => {
      const cover = section.querySelector('.cover')
      const container = section.querySelector('.animation-container')

      if (sections[index + 1]) {
        gsap.to(cover, {
          opacity: 0.4,
          scrollTrigger: {
            trigger: sections[index + 1],
            start: 'top 100%',
            end: 'bottom 50%',
            scrub: true,
          },
        })
        gsap.to(container, {
          y: 300,
          scrollTrigger: {
            trigger: sections[index + 1],
            start: 'top 100%',
            end: 'bottom 00%',
            scrub: true,
          },
        })
      }
    })
  }

  document.addEventListener('astro:page-load', setup)
</script>
