---
import { cn } from '@/lib/utils'
import { Moon, Sun, SunMedium } from 'lucide-react'
import { buttonVariants } from './ui/button'
---

<button
  theme-toggle-btn
  class={cn(
    buttonVariants({ variant: 'ghost', size: 'icon' }),
    'theme-toggle-btn pointer-fine:size-6 pointer-fine:cursor-pointer pointer-fine:rounded-sm',
  )}
>
  <Moon className="theme-icon theme-icon-dark size-4" />
  <Sun className="theme-icon theme-icon-light size-4" />
  <SunMedium className="theme-icon theme-icon-sunny size-4" />
  <span class="sr-only">Toggle theme</span>
</button>

<style is:global>
  html.dark .theme-icon-light,
  html.dark .theme-icon-sunny,
  html.light .theme-icon-dark,
  html.light .theme-icon-sunny,
  html.sunny .theme-icon-dark,
  html.sunny .theme-icon-light,
  html:not(.dark):not(.light):not(.sunny) .theme-icon-dark,
  html:not(.dark):not(.light):not(.sunny) .theme-icon-sunny {
    display: none;
  }
</style>

<script is:inline data-astro-rerun>
  const theme = (() => {
    const stored = localStorage?.getItem('crisfsdev-theme') ?? ''
    if (['dark', 'light', 'sunny'].includes(stored)) return stored
    if (window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark'
    return 'light'
  })()

  document.documentElement.classList.remove('dark', 'light', 'sunny')
  document.documentElement.classList.add(theme)
  window.localStorage.setItem('crisfsdev-theme', theme)
</script>

<script>
  const THEMES = ['dark', 'light', 'sunny'] as const
  type Theme = (typeof THEMES)[number]

  function isTheme(v: string | null): v is Theme {
    return v !== null && (THEMES as readonly string[]).includes(v)
  }

  function getCurrentTheme(): Theme {
    const el = document.documentElement
    if (el.classList.contains('dark')) return 'dark'
    if (el.classList.contains('sunny')) return 'sunny'
    return 'light'
  }

  function getNextTheme(current: Theme): Theme {
    return THEMES[(THEMES.indexOf(current) + 1) % THEMES.length]
  }

  function applyTheme(theme: Theme) {
    const el = document.documentElement
    el.classList.add('disable-transitions')
    el.classList.remove('dark', 'light', 'sunny')
    el.classList.add(theme)
    window.getComputedStyle(el).getPropertyValue('opacity')
    requestAnimationFrame(() => el.classList.remove('disable-transitions'))
    localStorage.setItem('crisfsdev-theme', theme)
    document.dispatchEvent(new CustomEvent('theme-changed', { detail: theme }))
  }

  function initThemeToggle() {
    const btns = document.querySelectorAll('[theme-toggle-btn]')
    btns.forEach((btn) => {
      btn?.addEventListener('click', () =>
        applyTheme(getNextTheme(getCurrentTheme())),
      )
    })
  }

  initThemeToggle()

  document.addEventListener('astro:after-swap', () => {
    const stored = localStorage.getItem('crisfsdev-theme')
    if (isTheme(stored)) applyTheme(stored)
    initThemeToggle()
  })

  document.addEventListener('keydown', (event) => {
    if (event.key.toLowerCase() === 't') {
      applyTheme(getNextTheme(getCurrentTheme()))
    }
  })
</script>
