---
import type { CollectionEntry } from 'astro:content'
import Link from './link.astro'

interface Props {
  entry: CollectionEntry<'writing'>
}

const { entry } = Astro.props
---

<div class="group project-card transition-colors">
  <Link
    href={`/${entry.collection}/${entry.id}`}
    class="flex flex-col gap-4 sm:flex-row"
  >
    <div class="flex grow flex-col items-start">
      <h3
        class="after:bg-foreground relative mb-1 font-medium after:absolute after:bottom-0 after:left-0 after:h-[1px] after:w-0 after:origin-bottom-left after:transition-all after:duration-300 group-hover:after:w-full hover:after:origin-bottom-right"
      >
        {entry.data.title}
      </h3>
      <p class="text-muted-foreground text-sm">{entry.data.description}</p>
    </div>
  </Link>
</div>
