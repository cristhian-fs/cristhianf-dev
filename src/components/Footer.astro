---
import { SOCIAL_LINKS } from '@/consts'
import SocialIcons from './SocialIcons.astro'
import ThemeToggle from './ThemeToggle.astro'
---

<footer class="bg-popover relative z-10 mt-10 w-full border-t py-2">
  <div
    class="mx-auto flex max-w-[35rem] flex-col items-center justify-center gap-y-2 px-4 sm:flex-row sm:justify-between"
  >
    <div class="flex flex-wrap items-center justify-center gap-x-2 text-center">
      <span class="text-muted-foreground text-sm">
        &copy; {new Date().getFullYear()} Cristhian F.
      </span>
    </div>
    <!-- <SocialIcons links={SOCIAL_LINKS} /> -->
    <ThemeToggle />
  </div>
</footer>
